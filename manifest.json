{
  "manifest_version": 3,
  "name": "Okta Login Helper",
  "version": "1.0.0",
  "description": "Automatically fills in your Okta username, checks 'Remember Me', and clicks Next to speed up login.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.okta.com/*",
    "https://*.okta-emea.com/*",
    "https://*.oktapreview.com/*",
    "https://*.login.samba.tv/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.okta.com/*",
        "https://*.okta-emea.com/*",
        "https://*.oktapreview.com/*",
        "https://*.login.samba.tv/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Okta Login Helper",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
